{
  "name": "@repo/shared",
  "version": "0.0.0",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./analytics": "./src/analytics/index.ts",
    "./ai-sdk": "./src/ai-sdk/index.ts",
    "./utils": "./src/utils/index.ts"
  },
  "scripts": {
    "base:prettier": "prettier './**/*.{ts,tsx,html,json,md,css}' --config .prettierrc --cache",
    "base:eslint": "eslint ./ --cache",
    "lint:prettier": "pnpm base:prettier --check",
    "lint:eslint": "pnpm base:eslint",
    "lint": "pnpm lint:prettier && pnpm lint:eslint",
    "format:prettier": "pnpm base:prettier --write",
    "format:eslint": "pnpm base:eslint --fix",
    "format": "pnpm format:prettier && pnpm format:eslint",
    "format-silent": "pnpm format:prettier --loglevel silent && pnpm format:eslint --quiet",
    "type:check": "tsc --noEmit"
  },
  "peerDependencies": {
    "next": ">=16",
    "react": ">=19.2.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.0",
    "@types/facebook-pixel": "^0.0.31",
    "@types/react": "19.2.14",
    "eslint-config-web": "workspace:*",
    "next": "16.1.6",
    "postcss": "8.5.6",
    "prettier-config-web": "workspace:*",
    "react": "19.2.4",
    "tailwind-config": "workspace:*",
    "tsconfig": "workspace:*",
    "typescript": "5.9.3"
  },
  "dependencies": {
    "@ai-sdk/google": "^2.0.26",
    "@ai-sdk/openai": "^2.0.59",
    "@ai-sdk/react": "^3.0.51",
    "@braze/web-sdk": "^6.5.0",
    "@next/third-parties": "^16.1.6",
    "ai": "^5.0.85",
    "braze-api": "^2.13.2",
    "posthog-js": "^1.357.0",
    "uuid": "^13.0.0"
  }
}
