{
  "name": "reviews-analyser",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "base:prettier": "prettier './**/*.{ts,tsx,html,json,md,css}' --config .prettierrc --cache",
    "base:eslint": "eslint ./ --cache",
    "lint:prettier": "pnpm base:prettier --check",
    "lint:eslint": "pnpm base:eslint",
    "lint": "pnpm lint:prettier && pnpm lint:eslint",
    "format:prettier": "pnpm base:prettier --write",
    "format:eslint": "pnpm base:eslint --fix",
    "format": "pnpm format:prettier && pnpm format:eslint",
    "format-silent": "pnpm format:prettier --loglevel silent && pnpm format:eslint --quiet",
    "type:check": "tsc --noEmit"
  },
  "dependencies": {
    "@repo/shared": "workspace:*",
    "next": "16.1.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-icons": "^5.5.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
