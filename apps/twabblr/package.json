{
  "name": "twabblr",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "base:prettier": "prettier './**/*.{ts,tsx,html,json,md,css}' --config .prettierrc --cache",
    "base:eslint": "eslint ./ --cache",
    "lint:prettier": "pnpm base:prettier --check",
    "lint:eslint": "pnpm base:eslint",
    "lint": "pnpm lint:prettier && pnpm lint:eslint",
    "format:prettier": "pnpm base:prettier --write",
    "format:eslint": "pnpm base:eslint --fix",
    "format": "pnpm format:prettier && pnpm format:eslint",
    "format-silent": "pnpm format:prettier --loglevel silent && pnpm base:eslint --quiet",
    "type:check": "tsc --noEmit",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@headlessui/react": "^2.1.2",
    "@auth/prisma-adapter": "^2.8.0",
    "@prisma/client": "^6.19.0",
    "axios": "^1.7.7",
    "bcrypt": "^5.1.1",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "lodash": "^4.17.21",
    "next": "16.1.6",
    "next-auth": "5.0.0-beta.30",
    "next-cloudinary": "^6.6.2",
    "pusher": "^5.2.0",
    "pusher-js": "^8.4.0-rc2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.52.1",
    "react-hot-toast": "^2.4.1",
    "react-icons": "^5.2.1",
    "react-select": "^5.8.0",
    "react-spinners": "^0.14.1",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcrypt": "^5.0.2",
    "@types/lodash": "^4.17.7",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "prettier-config-web": "workspace:*",
    "prisma": "^6.19.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
