{
  "private": true,
  "version": "1.10.2",
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "build": "turbo build",
    "start": "turbo start",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "lint:eslint": "turbo lint:eslint",
    "lint:prettier": "turbo lint:prettier",
    "clean": "turbo clean",
    "format": "turbo format",
    "format:prettier": "turbo format:prettier",
    "format:eslint": "turbo format:eslint",
    "type:check": "turbo type:check",
    "prepare": "husky",
    "reusable-components": "turbo dev --filter=reusable-components",
    "n-drive": "turbo dev --filter=n-drive",
    "backyard-skies": "turbo dev --filter=backyard-skies",
    "desktop-weather": "turbo dev --filter=desktop-weather",
    "reviews-analyser": "turbo dev --filter=reviews-analyser",
    "friends-of-nature": "turbo dev --filter=friends-of-nature",
    "blog-dev": "turbo dev --filter=blog-dev",
    "to-do-cards": "turbo dev --filter=to-do-cards",
    "twabblr": "turbo dev --filter=twabblr",
    "elysantium": "turbo dev --filter=elysantium"
  },
  "devDependencies": {
    "@commitlint/cli": "20.4.2",
    "@commitlint/config-conventional": "20.3.1",
    "eslint": "^9",
    "husky": "9.1.7",
    "tsconfig": "workspace:*",
    "turbo": "2.8.0"
  },
  "pnpm": {
    "peerDependencyRules": {
      "allowedVersions": {
        "react": "19",
        "react-dom": "19",
        "next": "16"
      }
    },
    "onlyBuiltDependencies": [
      "@clerk/shared",
      "bcrypt",
      "core-js",
      "esbuild",
      "protobufjs",
      "sharp",
      "unrs-resolver",
      "@prisma/client",
      "@prisma/engines",
      "prisma"
    ]
  }
}
