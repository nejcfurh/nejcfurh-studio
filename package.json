{
  "private": true,
  "version": "1.1.0",
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "build": "turbo build",
    "start": "turbo start",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "lint:eslint": "turbo lint:eslint",
    "lint:prettier": "turbo lint:prettier",
    "clean": "turbo clean",
    "format": "turbo format",
    "format:prettier": "turbo format:prettier",
    "format:eslint": "turbo format:eslint",
    "type:check": "turbo type:check",
    "prepare": "husky",
    "reusable-components": "turbo dev --filter=reusable-components",
    "n-drive": "turbo dev --filter=n-drive"
  },
  "devDependencies": {
    "@commitlint/cli": "20.4.2",
    "@commitlint/config-conventional": "20.3.1",
    "eslint": "9.39.2",
    "husky": "9.1.7",
    "tsconfig": "workspace:*",
    "turbo": "2.8.0"
  },
  "pnpm": {
    "peerDependencyRules": {
      "allowedVersions": {
        "react": "19",
        "react-dom": "19",
        "next": "16"
      }
    },
    "onlyBuiltDependencies": [
      "@clerk/shared",
      "core-js",
      "esbuild",
      "protobufjs",
      "sharp",
      "unrs-resolver"
    ]
  }
}
